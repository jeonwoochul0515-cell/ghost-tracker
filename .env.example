# Ghost Bidder Tracker — 환경변수 템플릿
# `cp .env.example .env` 후 값 채워서 사용.

# ─── 프론트 (Vite) ────────────────────────────────────────────────────
# Supabase 프로젝트 URL (예: https://xxxx.supabase.co 또는 http://localhost:54321)
VITE_SUPABASE_URL=

# Supabase anon (public) 키 — 브라우저 노출 안전한 공개키
VITE_SUPABASE_ANON_KEY=

# Mock 모드 활성화 (실제 Supabase 연결 없이 시드 데이터로 동작)
# 'true' 일 때만 mock 사용. 비워두면 실제 Supabase 호출.
VITE_USE_MOCK=true

# ─── Edge Functions / Server (supabase secrets) ──────────────────────
# 공공데이터포털(data.go.kr) 마스터 키 — eaT(학교급식전자조달) + 국세청(사업자등록정보) 등에서 공통 사용.
# 각 서비스를 포털에서 활성화 신청 후 동일 키로 호출 가능.
PUBLIC_DATA_API_KEY=

# eaT(학교급식전자조달) 전용 키 — 보통 PUBLIC_DATA_API_KEY 와 동일.
EAT_SERVICE_KEY=

# 국세청 사업자등록정보 진위확인 API 키 — 보통 PUBLIC_DATA_API_KEY 와 동일.
NTS_SERVICE_KEY=

# 브이월드(VWorld) 지도/지오코더 키
VWORLD_API_KEY=

# 도로명주소 검색 API (business.juso.go.kr) — 별도 가입+발급 필요.
JUSO_API_KEY=

# 사법정보공유포털 — 신청 진행 중.
COURT_API_KEY=
